    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            local pBtn = Instance.new("TextButton", WScroll)
            pBtn.Size = UDim2.new(1, -6, 0, 18)
            pBtn.Font = Enum.Font.GothamBold
            pBtn.TextSize = 8
