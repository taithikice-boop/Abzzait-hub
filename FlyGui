-- Hàm tạo nút bấm nhanh
local function createButton(parent, text, size, position, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = size
    btn.Position = position
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- =========================================================
-- [CORE LOGIC - HỆ THỐNG BAY LƯỢT (FLY HACK)]
-- =========================================================
local isFlying = false
local flySpeed = 50
local bV, bG, flyConnection

local ToggleBtn

-- Hàm xử lý Bật / Tắt bay
local function ToggleFly()
    isFlying = not isFlying
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then
        isFlying = false
        return
    end
    
    if isFlying then
        ToggleBtn.Text = "Fly Hack: ACTIVE (X)"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(30, 160, 30) -- Màu xanh lá khi bật
        
        -- Tạo lực đẩy vận tốc và giữ hướng xoay của nhân vật
        bV = Instance.new("BodyVelocity", hrp)
        bV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bV.Velocity = Vector3.new(0, 0, 0)
        
        bG = Instance.new("BodyGyro", hrp)
        bG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        bG.CFrame = hrp.CFrame
        
        -- Vòng lặp Render cập nhật hướng chuyển động theo camera
        flyConnection = RunService.RenderStepped:Connect(function()
            if not isFlying or not hrp or not bV or not bG then 
                return 
            end
            local camCFrame = Workspace.CurrentCamera.CFrame
            local moveVector = Vector3.new(0, 0, 0)
            
            -- Đọc trạng thái nhấn phím di chuyển
            if UIS:IsKeyDown(Enum.KeyCode.W) then 
                moveVector = moveVector + camCFrame.LookVector 
            end
            if UIS:IsKeyDown(Enum.KeyCode.S) then 
                moveVector = moveVector - camCFrame.LookVector 
            end
            if UIS:IsKeyDown(Enum.KeyCode.A) then 
                moveVector = moveVector - camCFrame.RightVector 
            end
            if UIS:IsKeyDown(Enum.KeyCode.D) then 
                moveVector = moveVector + camCFrame.RightVector 
            end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then 
                moveVector = moveVector + Vector3.new(0, 1, 0) 
            end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then 
                moveVector = moveVector - Vector3.new(0, 1, 0) 
            end
            
            -- Áp dụng lực vận tốc lên nhân vật
            bV.Velocity = (moveVector.Magnitude > 0) and (moveVector.Unit * flySpeed) or Vector3.new(0, 0, 0)
            bG.CFrame = camCFrame
        end)
    else
        ToggleBtn.Text = "Fly Hack: OFF (X)"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        -- Dọn dẹp các lực khi tắt bay
        if flyConnection then 
            flyConnection:Disconnect() 
            flyConnection = nil 
        end
        if bV then 
            bV:Destroy() 
            bV = nil 
        end
        if bG then 
            bG:Destroy() 
            bG = nil 
        end
    end
end

