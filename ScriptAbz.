local function GetTargetsIncludingDummies()
    local targets = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then table.insert(targets, p.Character) end
    end
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            if not Players:GetPlayerFromCharacter(obj) and obj ~= lp.Character and obj.Humanoid.Health > 0 then table.insert(targets, obj) end
        end
    end
    return targets
end

local function RunKillAllLoop()
    if loopKillAllActive then return end
    loopKillAllActive = true
    task.spawn(function()
        while toggledKillAll do
            local targets = GetTargetsIncludingDummies()
            if #targets > 0 then
                local target = targets[math.random(1, #targets)]
                local myChar = lp.Character
                local hrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local targetHrp = target:FindFirstChild("HumanoidRootPart")
                if hrp and targetHrp then
                    local backOffset = targetHrp.CFrame.LookVector * BACK_OFFSET_DISTANCE
                    local targetPos = Vector3.new(targetHrp.Position.X - backOffset.X, targetHrp.Position.Y, targetHrp.Position.Z - backOffset.Z)
                    myChar:PivotTo(CFrame.new(targetPos, targetHrp.Position))
                end
            end
            task.wait(SPEED_TUNER)
        end
        loopKillAllActive = false
    end)
end

local function ToggleKillAll()
    local targetState = not toggledKillAll ResetAllStates() toggledKillAll = targetState UpdateVisuals()
    if toggledKillAll then RunKillAllLoop() end
end

local function StartFly()
    local char = lp.Character local hrp = char and char:FindFirstChild("HumanoidRootPart") if not hrp then return end
    bV = Instance.new("BodyVelocity", hrp) bV.MaxForce = Vector3.new(1e5, 1e5, 1e5) bV.Velocity = Vector3.new(0, 0, 0)
    bG = Instance.new("BodyGyro", hrp) bG.MaxTorque = Vector3.new(1e5, 1e5, 1e5) bG.CFrame = hrp.CFrame
    flyConnection = RunService.RenderStepped:Connect(function()
        if not isFlying or not hrp or not bV or not bG then return end
        local camCFrame = workspace.CurrentCamera.CFrame local moveVector = Vector3.new(0, 0, 0)
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + camCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - camCFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - camCFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + camCFrame.RightVector end 
        if UIS:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end
        bV.Velocity = (moveVector.Magnitude > 0) and (moveVector.Unit * flySpeed) or Vector3.new(0, 0, 0)
        bG.CFrame = camCFrame
    end)
end

local function ToggleFly()
    local targetState = not isFlying ResetAllStates() isFlying = targetState UpdateVisuals()
    if isFlying then StartFly() end
end

local function StartOrbit()
    orbitConnection = RunService.Heartbeat:Connect(function()
        if not isOrbiting or not SelectedPlayer or not SelectedPlayer.Character then return end
        local targetHrp = SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myHrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if targetHrp and myHrp then
            angle = angle + (orbitSpeed / 100)
            local offset = Vector3.new(math.cos(angle) * orbitDistance, 0, math.sin(angle) * orbitDistance)
            myHrp.CFrame = CFrame.new(targetHrp.Position + offset, targetHrp.Position)
            myHrp.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end

local function StartUnderground()
    underConnection = RunService.Heartbeat:Connect(function()
        if not isUnderground or not SelectedPlayer or not SelectedPlayer.Character then return end
        local targetHrp = SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myHrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if targetHrp and myHrp then
            myHrp.CFrame = CFrame.new(targetHrp.Position + Vector3.new(0, -6, 0), targetHrp.Position + Vector3.new(0, 5, 0))
            myHrp.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end

local function TPToSelectedPlayer()
    if not SelectedPlayer or not SelectedPlayer.Character then return end
    local targetHrp = SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
    local myChar = lp.Character
    if targetHrp and myChar then
        myChar:PivotTo(targetHrp.CFrame * CFrame.new(0, 3, 0))
    end
end

