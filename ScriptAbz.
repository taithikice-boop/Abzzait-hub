local function TeleportToPosition(targetCFrame)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if tpMode == "Instant" then
        char:PivotTo(targetCFrame)
    else
        local distance = (hrp.Position - targetCFrame.Position).Magnitude
        local duration = math.clamp(distance / currentTweenSpeed, 0.2, 6)
        
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
        
        local bV_anti = Instance.new("BodyVelocity", hrp)
        bV_anti.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bV_anti.Velocity = Vector3.new(0,0,0)
        
        tween:Play()
        tween.Completed:Connect(function() bV_anti:Destroy() end)
    end
end

